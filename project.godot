; Godot RPG - Project Configuration
; Proyecto base para RPG por turnos

[application]
config/name="RPG Sin Título"
config/description="Un RPG por turnos en pixel art"
run/main_scene="res://Scenes/main.tscn"
config/icon="res://icon.png"
config/windows_title="RPG Sin Título"

[display]
window/size/viewport_width=320
window/size/viewport_height=180
window/size/window_width_override=960
window/size/window_height_override=540
window/size/mode=0
window/size/stretch/mode="canvas_items"
window/size/stretch/aspect="keep"

[autoload]

GameState="*res://Scripts/game_state.gd"

[rendering]
renderer/rendering_method="gl_compatibility"
